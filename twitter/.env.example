# X app OAuth 2.0 credentials.
# developer.x.com → your app → "User authentication settings" → OAuth 2.0
# App type must be "Web App" (confidential client).
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=

# Seed refresh token from the one-time consent flow:
#   npx tsx scripts/authorize.ts
X_REFRESH_TOKEN=

# Optional. Timeline pages (100 posts each) scanned to rebuild threads older
# than 7 days. Each returned post bills ~$0.005; raise for prolific authors.
# X_THREAD_TIMELINE_PAGES=3

# Optional. Change to any new value (and `ntn workers env push`) to force a
# full re-fetch of all bookmarks on the next cycle.
# X_FULL_RESYNC=

# Optional. Cap bookmarks fetched in a full-load cycle (default 850);
# set to 10 for a cheap trial run.
# X_FULL_LOAD_LIMIT=

# Optional. Set to 1 to pause the sync (no API calls, no token refresh).
# X_PAUSED=
